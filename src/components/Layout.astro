i---
import '../styles/global.css';
// removed node fs/path imports; use Vite raw import for CSV instead

const title = (Astro && Astro.props && Astro.props.title) || '';
const pathname = (Astro && Astro.url && Astro.url.pathname) || '';
const isGermanPage = pathname === '/de' || pathname === '/de/' || pathname.startsWith('/de/');

const routeMap = new Map([
  ['home', '/'],
  ['about us', '/about-us'],
  ['contact us', '/contact'],
  ['contact', '/contact'],
  ['powdercoat eq', '/powdercoat-equipment'],
  ['marble', '/polished-marble'],
  ['cnc machines', '/cnc-machine-supplier'],
  ['dubai flat', '/dubai-rak-flat-finder'],
  ['dubai wohnung', '/de/dubai-wohnung-kaufen'],
  ['offers', '/offers'],

  ['automated line', '/automated'],
  ['get started', '/get-started-powder-coating'],
  ['booth', '/powder-coating-booth'],
  ['oven', '/powder-coating-oven'],
  ['mdf coating', '/mdf-powder-coating-line'],
  ['alu profiles plant', '/powdercoat-aluminium-profiles'],
  ['enamel powder', '/enamel-powdercoat'],
  ['special spray gun', '/powder-coating-machine'],

  ['heesemann sander', '/heesemann-sander'],
  ['dust collection', '/dust-collection'],
  ['used machines in uae', '/used-machines'],
  ['sliding table saw', '/sliding-table-saw'],
  ['edge banding', '/edge-banding'],
  ['wood hot press', '/hot-pressing'],
  ['cnc router', '/cnc-router'],
  ['fiber laser welding', '/fiber-laser'],
  ['cnc miling', '/cnc-miling'],
  ['fiber laser cutting', '/coil-fed-fiber-laser-cutting-machine-uae'],
]);

function slugifyLabel(label) {
  const normalized = label.toLowerCase().trim().replace(/&/g, ' and ').replace(/\s+/g, ' ').replace(/[^a-z0-9 ]+/g, '').trim();
  return routeMap.get(normalized) || `/${normalized.replace(/\s+/g, '-')}`;
}

function buildNavFromCsv(csvText, isGerman) {
  const rows = csvText.split(/\r?\n/).map(line => line.trim());
  const nav = [];
  let currentMain = null;

  for (const row of rows) {
    if (!row) continue;
    const [left, right] = row.split(',').map(cell => cell.trim());
    if (left && left.toLowerCase() === 'menu link') {
      continue;
    }

    if (left) {
      const normalized = left.toLowerCase().trim().replace(/&/g, ' and ').replace(/\s+/g, ' ').replace(/[^a-z0-9 ]+/g, '').trim();
      if (!isGerman && normalized === 'dubai wohnung') {
        continue;
      }

      currentMain = {
        title: left,
        href: slugifyLabel(left),
        children: [],
      };
      nav.push(currentMain);
    } else if (right && currentMain) {
      currentMain.children.push({
        title: right,
        href: slugifyLabel(right),
      });
    }
  }
  return nav;
}

import menucsv from '../../public/menusp.csv?raw';
const navItems = buildNavFromCsv(menucsv, isGermanPage);

function renderNavHtml(items) {
  let out = '';
  for (let i = 0; i < items.length; i++) {
    const item = items[i];
    if (item.children && item.children.length > 0) {
      out += `<li class="nav-item dropdown">`;
      out += `<a class="nav-link dropdown-toggle" href="${item.href || '#'}" id="navDropdown${i}" role="button" data-bs-toggle="dropdown" aria-expanded="false">${item.title}</a>`;
      out += `<ul class="dropdown-menu" aria-labelledby="navDropdown${i}">`;
      for (let j = 0; j < item.children.length; j++) {
        const c = item.children[j];
        out += `<li><a class="dropdown-item" href="${c.href}">${c.title}</a></li>`;
      }
      out += `</ul></li>`;
    } else {
      out += `<li class="nav-item"><a class="nav-link" href="${item.href}">${item.title}</a></li>`;
    }
  }
  return out;
}

const navHtml = renderNavHtml(navItems);
