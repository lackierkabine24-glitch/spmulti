const body = "<section class=\"section-soft py-5\"><div class=\"container\"><h2 class=\"mb-4\">Related stone products</h2><div class=\"row g-4\"><div class=\"col-md-4\"><div class=\"card p-4\"><h3 class=\"h5\">Polished high quality marble</h3><p class=\"text-muted\">Any natural design available</p><p><a class=\"fw-bold\" href=\"/polished-marble\">Open page</a></p></div></div><div class=\"col-md-4\"><div class=\"card p-4\"><h3 class=\"h5\">Lime Stone</h3><p class=\"text-muted\">Lime Stone</p><p><a class=\"fw-bold\" href=\"/lime-stone\">Open page</a></p></div></div><div class=\"col-md-4\"><div class=\"card p-4\"><h3 class=\"h5\">Porcelain Tiles Dubai</h3><p class=\"text-muted\">Premium slabs at direct factory prices</p><p><a class=\"fw-bold\" href=\"/porcelain-tiles-dubai\">Open page</a></p></div></div><div class=\"col-md-4\"><div class=\"card p-4\"><h3 class=\"h5\">Ceramic Tiles RAK</h3><p class=\"text-muted\">Premium slabs at direct factory prices</p><p><a class=\"fw-bold\" href=\"/ceramic-tiles-rak\">Open page</a></p></div></div><div class=\"col-md-4\"><div class=\"card p-4\"><h3 class=\"h5\">Luxury Tiles GCC</h3><p class=\"text-muted\">Flooring &amp; Wall – For Prestige Projects</p><p><a class=\"fw-bold\" href=\"/luxury-tiles-gcc\">Open page</a></p></div></div><div class=\"col-md-4\"><div class=\"card p-4\"><h3 class=\"h5\">Travertine Stones Wholesale GCC</h3><p class=\"text-muted\">From source mine</p><p><a class=\"fw-bold\" href=\"/travertine-gcc-wholesale\">Open page</a></p></div></div><div class=\"col-md-4\"><div class=\"card p-4\"><h3 class=\"h5\">Outdoor Marble Abu Dhabi</h3><p class=\"text-muted\">Premium look, long-lasting</p><p><a class=\"fw-bold\" href=\"/outdoor-marble-abu-dhabi\">Open page</a></p></div></div><div class=\"col-md-4\"><div class=\"card p-4\"><h3 class=\"h5\">Floor Tiles Premium Projects</h3><p class=\"text-muted\">Bulk prices for developers</p><p><a class=\"fw-bold\" href=\"/floor-tiles-premium-projects\">Open page</a></p></div></div><div class=\"col-md-4\"><div class=\"card p-4\"><h3 class=\"h5\">White Marble for Arabia</h3><p class=\"text-muted\">Direct Quarry Prices, white Mugla or Afyon sugar marble, similar to Calacatta</p><p><a class=\"fw-bold\" href=\"/white-marble-arabia\">Open page</a></p></div></div></div></div></section><section class=\"py-5\"><div class=\"container\"><h2>FAQ</h2><div class=\"accordion\" id=\"faq\"><div class=\"accordion-item\"><h3 class=\"accordion-header\" id=\"q1\"><button class=\"accordion-button\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#a1\">What are the best bathroom tiles / kitchen tiles for Dubai projects?</button></h3><div class=\"accordion-collapse collapse show\" id=\"a1\" data-bs-parent=\"#faq\"><div class=\"accordion-body\">The best choice depends on the project: outdoor areas need anti-slip and heat-resistant surfaces, bathrooms need water-safe finishes, and luxury interiors often use marble, porcelain slabs or honed natural stone.</div></div></div><div class=\"accordion-item\"><h3 class=\"accordion-header\" id=\"q2\"><button class=\"accordion-button collapsed\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#a2\">Can you supply cut-to-size and project quantities?</button></h3><div class=\"accordion-collapse collapse\" id=\"a2\" data-bs-parent=\"#faq\"><div class=\"accordion-body\">Yes. The product data includes recurring terms such as cut-to-size marble, slabs, pavers, mosaics, countertops and boxed tile quantities, which are useful for project supply and procurement pages.</div></div></div></div></div></section><footer class=\"py-5\"><div class=\"container\"><div class=\"row g-4\"><div class=\"col-lg-5\"><h3>Stone wholesale supplier</h3><p class=\"text-white-50\">Tile, marble, travertine and natural stone supply in GCC. UAE, Saudi Arabia, Oman, Qatar, Kuwait and Bahrain.</p></div><div class=\"col-lg-7\"><h4 class=\"h6 text-uppercase\">Internal links</h4><ul class=\"list-unstyled columns-2\"><li><a href=\"/marble-wall-panel\">Marble wall panel HD printed no PVC</a></li><li><a href=\"/polished-marble\">Polished Marble</a></li><li><a href=\"/lime-stone\">Lime Stone</a></li><li><a href=\"/porcelain-tiles-dubai\">Porcelain Tiles in Dubai</a></li><li><a href=\"/ceramic-tiles-rak\">Ceramic Tiles RAK</a></li><li><a href=\"/luxury-tiles-gcc\">Luxury Tiles GCC</a></li><li><a href=\"/travertine-gcc-wholesale\">Travertine Stones Wholesale</a></li><li><a href=\"/outdoor-marble-abu-dhabi\">Outdoor Marble Abu Dhabi</a></li><li><a href=\"/floor-tiles-premium-projects\">Floor Tiles Premium Projects</a></li><li><a href=\"/white-marble-arabia\">White Marble Arabia</a></li></ul></div></div></div></footer>";
